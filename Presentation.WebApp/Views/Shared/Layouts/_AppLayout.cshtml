@{
    var title = ViewData["Title"]?.ToString();
    var pageTitle = !string.IsNullOrWhiteSpace(title) ? $"{title} | CoreFitness" : "CoreFitness Club | Fitness and Gym";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>
<body>
    <div class="app-layout">
        <header>
            <partial name="Partials/Globals/_HeaderSection" />
            @await RenderSectionAsync("Hero", required: false)

        </header>
        <partial name="Partials/Globals/_PageTitleSection" />

        <main>
            @RenderBody()
        </main>
        <footer>
            <partial name="Partials/Globals/_FooterSection" />
        </footer>
    </div>

   
    <script src="~/js/lib/jquery.min.js"></script>
    <script>
            if (typeof jQuery !== "undefined" && !jQuery.parseJSON) {
                jQuery.parseJSON = function (data) {
                    return JSON.parse(data);
                };
            }
    </script>
    <script src="~/js/lib/jquery.validate.min.js"></script>
    <script src="~/js/lib/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js"></script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
